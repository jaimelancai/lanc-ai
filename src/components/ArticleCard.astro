---
import type { Article } from '../lib/articles';
import FormattedDate from './FormattedDate.astro';

interface Props {
  article: Article;
}
const { article } = Astro.props;
const { title, description, pubDate, tags } = article.data;
---

<article class="group border-b border-neutral-800 py-6 last:border-b-0">
  <a href={`/articles/${article.id}`} class="block">
    <h2
      class="text-xl font-semibold text-neutral-100 group-hover:text-sky-400"
    >
      {title}
    </h2>
  </a>
  <div class="mt-1 text-sm text-neutral-500">
    <FormattedDate date={pubDate} />
  </div>
  <p class="mt-2 text-neutral-400">{description}</p>
  {
    tags.length > 0 && (
      <ul class="mt-3 flex flex-wrap gap-2">
        {tags.map((tag) => (
          <li class="rounded-full border border-neutral-800 bg-neutral-900 px-2.5 py-0.5 text-xs text-neutral-400">
            {tag}
          </li>
        ))}
      </ul>
    )
  }
</article>
