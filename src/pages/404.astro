---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="The page you’re looking for doesn’t exist.">
  <div class="py-16 text-center">
    <p class="font-mono text-5xl font-bold text-sky-400">404</p>
    <h1 class="mt-4 text-2xl font-bold text-neutral-100">Page not found</h1>
    <p class="mt-2 text-neutral-400">
      The page you’re looking for doesn’t exist or has moved.
    </p>
    <a
      href="/"
      class="mt-6 inline-block rounded-md border border-neutral-800 px-4 py-2 text-sm text-neutral-200 hover:border-sky-400 hover:text-sky-400"
    >
      &larr; Back to home
    </a>
  </div>
</BaseLayout>
