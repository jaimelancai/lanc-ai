---
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { getArticles } from '../lib/articles';
import {
  AUTHOR_NAME,
  AUTHOR_HEADLINE,
  AUTHOR_POSITIONING,
  AVATAR_SRC,
} from '../consts';

const articles = await getArticles();
---

<BaseLayout>
  <!-- Intro -->
  <section class="flex flex-col items-center gap-5 text-center sm:flex-row sm:text-left">
    <img
      src={AVATAR_SRC}
      alt={`Portrait of ${AUTHOR_NAME}`}
      width="96"
      height="96"
      class="h-24 w-24 shrink-0 rounded-full border border-neutral-800 object-cover"
    />
    <div>
      <h1 class="text-2xl font-bold text-neutral-100">{AUTHOR_NAME}</h1>
      <p class="mt-1 text-sm font-medium text-sky-400">{AUTHOR_HEADLINE}</p>
      <p class="mt-3 text-neutral-400">{AUTHOR_POSITIONING}</p>
    </div>
  </section>

  <!-- Article list -->
  <section class="mt-12">
    <h2 class="text-sm font-semibold tracking-wide text-neutral-500 uppercase">
      Latest articles
    </h2>
    <div class="mt-4">
      {
        articles.length > 0 ? (
          articles.map((article) => <ArticleCard article={article} />)
        ) : (
          <p class="py-6 text-neutral-400">No articles yet — check back soon.</p>
        )
      }
    </div>
  </section>
</BaseLayout>
